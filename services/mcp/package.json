{
  "name": "@ficecal/service-mcp",
  "version": "0.5.0",
  "description": "FiceCal v2 MCP service layer — Fastify HTTP transport around mcp-tooling economics tools",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "node --import tsx/esm src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ficecal/mcp-tooling": "workspace:*",
    "@ficecal/plugin-api": "workspace:*",
    "@ficecal/economics-module": "workspace:*",
    "@ficecal/health-score": "workspace:*",
    "@ficecal/recommendation-module": "workspace:*",
    "@ficecal/core-economics": "workspace:*",
    "@ficecal/ai-token-economics": "workspace:*",
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "ficecal": {
    "phase": 6,
    "status": "active"
  }
}
